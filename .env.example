# =============================================================================
# Demo module stack — environment template. Copy to .env.<env> and fill in.
#
#   local   -> .env.local     (laptop; == the compose built-in defaults)
#   test    -> .env.test
#   preprod -> .env.preprod
#   prod    -> .env.prod
#
# Run:  docker compose --env-file .env.<env> up -d
#   or  ./scripts/stack.ps1 -Action up -Environment <env>
#
# The SAME images run in every environment; only these values change. Anything
# you leave unset falls back to the local-dev default in docker-compose.yml
# (${VAR:-default}), so plain `docker compose up` (no --env-file) == .env.local.
#
# TWO ways compose reads env vars, and they DON'T combine:
#   * plain `.env` (untracked) is AUTO-READ by `docker compose` with no flags —
#     the handy spot for your local GEMINI_API_KEY during dev.
#   * a per-environment file passed via `--env-file .env.test/.preprod/.prod`
#     REPLACES that auto-read: `.env` is then NOT read at all. So each per-env
#     file must carry EVERY var it needs itself — including GEMINI_API_KEY and
#     DEMO_SERVICE_SECRET.
# =============================================================================

# --- Spring profile ----------------------------------------------------------
# dev  = dev endpoints + verbose SQL logging (laptop only)
# prod = quiet INFO logging, no SQL dump, no demo seed data
SPRING_PROFILES_ACTIVE=prod

# --- Platform IdP + portal ---------------------------------------------------
# MUST match the platform deployment for this environment. PLATFORM_ISSUER is
# the browser-visible IdP URL (the token `iss` claim must equal it). JWKS +
# registry are fetched server-side from inside the container: locally those go
# via host.docker.internal to reach the platform stack on the host; in shared
# envs use the platform's real hostname. Prod usually fronts platform with TLS.
PLATFORM_ISSUER=http://platform.example.local:8090
PLATFORM_JWKS_URI=http://platform.example.local:8090/oauth2/jwks
PLATFORM_REGISTRY_URL=http://platform.example.local:8090
PORTAL_URL=http://platform.example.local:8091

# --- Published ports (host side) ---------------------------------------------
# Full "host:container" (or "ip:host:container") publish specs. In prod, bind
# the DB port to localhost only, e.g. DEMO_DB_PUBLISH=127.0.0.1:5435:5432
DEMO_FRONTEND_PUBLISH=8085:80
DEMO_BACKEND_PUBLISH=8092:8080
DEMO_DB_PUBLISH=5435:5432

# --- Credentials (CHANGE THESE for anything non-local) -----------------------
DEMO_DB_NAME=demo
DEMO_DB_USER=demo
DEMO_DB_PASSWORD=change-me-strong
# Client-credentials secret for the central metadata registry. MUST match the
# demo-service secret hash registered on the platform for this environment.
DEMO_SERVICE_SECRET=change-me-strong

# --- Smart-navigation assistant (Google Gemini) ------------------------------
# Gemini API key — get one at https://aistudio.google.com/apikey. When unset,
# the assistant reports it isn't configured (the app still boots).
GEMINI_API_KEY=
# To ENABLE the Spring AI (Google GenAI) client, set ALL THREE together — the
# key above plus both switches below. The safe defaults (gemini / none) keep
# Spring AI's chat autoconfig OFF so a keyless boot (e.g. CI) doesn't fail.
#   APP_LLM_PROVIDER=google-genai
#   SPRING_AI_MODEL_CHAT=google-genai
APP_LLM_PROVIDER=gemini
SPRING_AI_MODEL_CHAT=none

# --- Image tags --------------------------------------------------------------
# Laptop builds these from source; other hosts load them via `docker load`.
DEMO_BACKEND_IMAGE=demo-backend:latest
DEMO_FRONTEND_IMAGE=demo-frontend:latest
