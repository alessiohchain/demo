{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./mvnw:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(docker compose:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git rev-parse:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://localhost:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf /:*)",
      "Bash(mvn deploy:*)",
      "Bash(npm publish:*)"
    ]
  }
}
