# Java / Maven
target/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath

# Node / frontend
node_modules/
dist/
build/
.next/
.turbo/
.cache/
coverage/
*.tsbuildinfo
.eslintcache
.npm
