.yarn/

# Env / secrets
# Real per-environment files hold credentials — keep them out of git.
# .env.example is the tracked template (see !.env.example below).
.env
.env.local
.env.*.local
.env.test
.env.preprod
.env.prod
!.env.example
*.pem
*.key
*.p12

# OS
.DS_Store
Thumbs.db
desktop.ini

# Claude Code — keep team config (.claude/settings.json, .mcp.json, CLAUDE.md),
# ignore personal overrides
.claude/settings.local.json
.claude/.session*
.claude/projects/

# Logs
*.log
*.log.*
logs/

# Docker
.docker/

# Office temp / lock files (e.g. ~$deck.pptx)
~$*

# Terraform plan output (binary, regenerated by `terraform plan`)
tfplan.bin
*.tfplan

# Local secrets (docker build token; written by scripts/redeploy.ps1)
.secrets/
